# Cloudways API Tool - Environment Variables
#
# These are passed through to the Docker container.
# Set the actual values in your shell environment or ~/.cloudways/.env

# Cloudways API Keys (from https://platform.cloudways.com/api)
CLOUDWAYS_API_KEY_PRIMARY=your_primary_api_key_here
CLOUDWAYS_API_KEY_AGENCY=your_agency_api_key_here

# Direct override (optional - overrides accounts.yml)
# CLOUDWAYS_EMAIL=your@email.com
# CLOUDWAYS_API_KEY=your_api_key_here

# Config path override (optional - overrides auto-discovery)
# CLOUDWAYS_PROJECT_CONFIG=/path/to/project-config.yml

# Accounts file override (optional - overrides default ~/.cloudways/accounts.yml)
# CLOUDWAYS_ACCOUNTS_FILE=/path/to/accounts.yml
